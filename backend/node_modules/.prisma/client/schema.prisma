generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String                      @id @default(uuid())
  googleId                  String?                     @unique @map("google_id")
  email                     String                      @unique
  name                      String
  avatarUrl                 String?                     @map("avatar_url")
  totalXp                   Int                         @default(0) @map("total_xp")
  currentStreak             Int                         @default(0) @map("current_streak")
  longestStreak             Int                         @default(0) @map("longest_streak")
  lastActivityDate          DateTime?                   @map("last_activity_date")
  createdAt                 DateTime                    @default(now()) @map("created_at")
  passwordHash              String?                     @map("password_hash") @db.VarChar(255)
  emailVerified             Boolean?                    @default(false) @map("email_verified")
  verificationCode          String?                     @map("verification_code") @db.VarChar(6)
  verificationCodeExpires   DateTime?                   @map("verification_code_expires") @db.Timestamp(6)
  resetToken                String?                     @map("reset_token") @db.VarChar(255)
  resetTokenExpires         DateTime?                   @map("reset_token_expires") @db.Timestamp(6)
  placementTestCompleted    Boolean?                    @default(false) @map("placement_test_completed")
  startingLevel             String?                     @map("starting_level") @db.VarChar(2)
  placementTestDate         DateTime?                   @map("placement_test_date") @db.Timestamp(6)
  aiChatMessages            AiChatMessage[]
  aiChatSessions            AiChatSession[]
  examAttempts              ExamAttempt[]
  exams                     Exam[]
  lessonCompletions         LessonCompletion[]
  levelResets               LevelReset[]
  placementTestAnswers      PlacementTestAnswer[]
  placementTests            PlacementTest?
  podcastCompletions        PodcastCompletion[]
  reading_completions       reading_completions[]
  speaking_attempts         speaking_attempts[]
  userProgress              UserProgress[]
  writing_submissions       writing_submissions[]
  writing_exercise_attempts writing_exercise_attempts[]

  @@map("users")
}

model Level {
  id                       String              @id
  code                     String              @unique
  name                     String
  description              String?
  order_index              Int?
  required_xp              Int                 @default(0)
  badge_icon_url           String?
  podcast_youtube_id       String?
  podcast_title            String?
  podcast_description      String?
  podcast_duration_minutes Int?
  created_at               DateTime            @default(now())
  isUnlockedByDefault      Boolean?            @default(false) @map("is_unlocked_by_default")
  unlockOrder              Int?                @map("unlock_order")
  colorCode                String?             @default("#3B82F6") @map("color_code") @db.VarChar(50)
  order                    Int?
  examAttempts             ExamAttempt[]
  exams                    Exam[]
  lessons                  Lesson[]
  levelResets              LevelReset[]
  podcasts                 Podcast[]
  questions                Question[]
  reading_passages         reading_passages[]
  speaking_tasks           speaking_tasks[]
  userProgress             UserProgress[]
  writing_prompts          writing_prompts[]
  writing_exercises        writing_exercises[]

  @@map("levels")
}

model UserProgress {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  levelId          String   @map("level_id")
  lessonsCompleted Int      @default(0) @map("lessons_completed")
  totalLessons     Int      @default(0) @map("total_lessons")
  isExamUnlocked   Boolean  @default(false) @map("is_exam_unlocked")
  examsPassed      Int      @default(0) @map("exams_passed")
  examsFailed      Int      @default(0) @map("exams_failed")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  level            Level    @relation(fields: [levelId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, levelId])
  @@map("user_progress")
}

model Lesson {
  id               String             @id @default(dbgenerated("gen_random_uuid()"))
  levelId          String             @map("level_id")
  title            String
  description      String?
  type             LessonType
  orderIndex       Int                @map("order_index")
  content          Json
  xpReward         Int                @default(10) @map("xp_reward")
  estimatedMinutes Int                @default(15) @map("estimated_minutes")
  createdAt        DateTime           @default(now()) @map("created_at")
  completions      LessonCompletion[]
  level            Level              @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@map("lessons")
}

model LessonCompletion {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  lessonId         String   @map("lesson_id")
  score            Int?
  timeSpentSeconds Int?     @map("time_spent_seconds")
  completedAt      DateTime @default(now()) @map("completed_at")
  lesson           Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_completions")
}

model Question {
  id               String           @id @default(uuid())
  levelId          String           @map("level_id")
  category         QuestionCategory
  type             QuestionType
  questionText     String           @map("question_text")
  options          Json?
  correctAnswer    String           @map("correct_answer")
  explanation      String?
  difficultyWeight Int              @default(1) @map("difficulty_weight")
  tags             String[]         @default([])
  isActive         Boolean          @default(true) @map("is_active")
  createdAt        DateTime         @default(now()) @map("created_at")
  level            Level            @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@map("questions")
}

model Exam {
  id               String     @id @default(uuid())
  userId           String     @map("user_id")
  levelId          String     @map("level_id")
  status           ExamStatus
  questions        Json
  answers          Json       @default("{}")
  score            Decimal?   @db.Decimal(5, 2)
  passed           Boolean?
  startedAt        DateTime   @default(now()) @map("started_at")
  completedAt      DateTime?  @map("completed_at")
  expiresAt        DateTime   @map("expires_at")
  timeTakenSeconds Int?       @map("time_taken_seconds")
  level            Level      @relation(fields: [levelId], references: [id], onDelete: Cascade)
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("exams")
}

model ExamAttempt {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  levelId       String   @map("level_id")
  examId        String   @map("exam_id")
  attemptNumber Int      @map("attempt_number")
  score         Decimal  @db.Decimal(5, 2)
  passed        Boolean
  attemptedAt   DateTime @default(now()) @map("attempted_at")
  level         Level    @relation(fields: [levelId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("exam_attempts")
}

model LevelReset {
  id      String   @id @default(uuid())
  userId  String   @map("user_id")
  levelId String   @map("level_id")
  reason  String
  resetAt DateTime @default(now()) @map("reset_at")
  level   Level    @relation(fields: [levelId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("level_resets")
}

// ========================================
// PODCAST MODELLERI (Güncellenmiş)
// ========================================

model Podcast {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  levelId       String    @map("level_id")
  title         String    @db.VarChar(255)
  description   String?
  audioUrl      String    @map("audio_url")
  duration      Int?
  difficulty    Int?      @default(1)
  episodeNumber Int?      @map("episode_number")
  transcript    String?
  thumbnailUrl  String?   @map("thumbnail_url")
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)

  level        Level               @relation(fields: [levelId], references: [id], onDelete: Cascade)
  vocabularies PodcastVocabulary[]
  exercises    PodcastExercise[]
  completions  PodcastCompletion[]

  @@index([levelId])
  @@index([levelId, episodeNumber])
  @@map("podcasts")
}

model PodcastVocabulary {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  podcastId       String    @map("podcast_id") @db.Uuid
  word            String    @db.VarChar(255)
  definition      String
  exampleSentence String?   @map("example_sentence")
  audioUrl        String?   @map("audio_url")
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  podcast Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  @@index([podcastId])
  @@map("podcast_vocabularies")
}

model PodcastExercise {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  podcastId     String    @map("podcast_id") @db.Uuid
  question      String
  options       Json
  correctAnswer String    @map("correct_answer")
  explanation   String?
  questionOrder Int?      @map("question_order")
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  podcast Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  @@index([podcastId])
  @@map("podcast_exercises")
}

model PodcastCompletion {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id")
  podcastId   String    @map("podcast_id") @db.Uuid
  completedAt DateTime? @default(now()) @map("completed_at") @db.Timestamp(6)
  score       Int?
  timeSpent   Int?      @map("time_spent")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  podcast Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  @@unique([userId, podcastId])
  @@index([userId])
  @@index([podcastId])
  @@map("podcast_completions")
}

model AiChatSession {
  id            String          @id @default(uuid())
  userId        String          @map("user_id")
  sessionId     String          @map("session_id")
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now()) @map("created_at")
  lastMessageAt DateTime        @default(now()) @map("last_message_at")
  messages      AiChatMessage[]
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionId])
  @@map("ai_chat_sessions")
}

model AiChatMessage {
  id        String        @id @default(uuid())
  sessionId String        @map("session_id")
  userId    String        @map("user_id")
  role      String
  content   String
  createdAt DateTime      @default(now()) @map("created_at")
  session   AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_chat_messages")
}

model PlacementTest {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String                @unique @map("user_id")
  completedAt     DateTime?             @map("completed_at") @db.Timestamp(6)
  totalQuestions  Int?                  @default(30) @map("total_questions")
  correctAnswers  Int?                  @default(0) @map("correct_answers")
  determinedLevel String?               @map("determined_level") @db.VarChar(2)
  createdAt       DateTime?             @default(now()) @map("created_at") @db.Timestamp(6)
  answers         PlacementTestAnswer[]
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_placement_tests_user_id")
  @@map("placement_tests")
}

model PlacementTestQuestion {
  id            String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  levelCode     String                @map("level_code") @db.VarChar(2)
  questionText  String                @map("question_text")
  options       Json
  correctAnswer String                @map("correct_answer")
  questionType  String?               @default("grammar") @map("question_type") @db.VarChar(50)
  difficulty    Int?                  @default(1)
  createdAt     DateTime?             @default(now()) @map("created_at") @db.Timestamp(6)
  answers       PlacementTestAnswer[]

  @@index([levelCode], map: "idx_placement_test_questions_level")
  @@map("placement_test_questions")
}

model PlacementTestAnswer {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  placementTestId String                @map("placement_test_id") @db.Uuid
  questionId      String                @map("question_id") @db.Uuid
  userAnswer      String?               @map("user_answer")
  isCorrect       Boolean?              @map("is_correct")
  createdAt       DateTime?             @default(now()) @map("created_at") @db.Timestamp(6)
  userId          String                @default("") @map("user_id")
  placementTest   PlacementTest         @relation(fields: [placementTestId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  question        PlacementTestQuestion @relation(fields: [questionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([placementTestId], map: "idx_placement_test_answers_test_id")
  @@index([userId], map: "idx_placement_test_answers_user")
  @@map("placement_test_answers")
}

model reading_completions {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String
  passage_id       String           @db.Uuid
  score            Int
  time_spent       Int?
  completed_at     DateTime?        @default(now()) @db.Timestamp(6)
  reading_passages reading_passages @relation(fields: [passage_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users            User             @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, passage_id])
  @@index([passage_id], map: "idx_reading_completions_passage")
  @@index([user_id], map: "idx_reading_completions_user")
}

model reading_passages {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  level_id            String
  title               String                @db.VarChar(255)
  content             String
  word_count          Int?
  estimated_time      Int?
  topic               String?               @db.VarChar(100)
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  reading_completions reading_completions[]
  levels              Level                 @relation(fields: [level_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  reading_questions   reading_questions[]

  @@index([level_id], map: "idx_reading_passages_level")
}

model reading_questions {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  passage_id       String           @db.Uuid
  question_text    String
  options          Json
  correct_answer   String
  question_order   Int?
  created_at       DateTime?        @default(now()) @db.Timestamp(6)
  reading_passages reading_passages @relation(fields: [passage_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([passage_id], map: "idx_reading_questions_passage")
}

model speaking_attempts {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String
  task_id        String         @db.Uuid
  audio_url      String?
  transcription  String?
  ai_feedback    Json?
  overall_score  Int?
  duration       Int?
  submitted_at   DateTime?      @default(now()) @db.Timestamp(6)
  speaking_tasks speaking_tasks @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users          User           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([task_id], map: "idx_speaking_attempts_task")
  @@index([user_id], map: "idx_speaking_attempts_user")
}

model speaking_tasks {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  level_id          String
  title             String              @db.VarChar(255)
  prompt_text       String
  task_type         String?             @db.VarChar(50)
  estimated_time    Int?
  created_at        DateTime?           @default(now()) @db.Timestamp(6)
  speaking_attempts speaking_attempts[]
  levels            Level               @relation(fields: [level_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([level_id], map: "idx_speaking_tasks_level")
}

model writing_prompts {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  level_id            String
  title               String                @db.VarChar(255)
  prompt_text         String
  prompt_type         String?               @db.VarChar(50)
  min_words           Int?
  max_words           Int?
  estimated_time      Int?
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  levels              Level                 @relation(fields: [level_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  writing_submissions writing_submissions[]

  @@index([level_id], map: "idx_writing_prompts_level")
}

model writing_submissions {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String
  prompt_id       String          @db.Uuid
  content         String
  word_count      Int?
  ai_feedback     Json?
  overall_score   Int?
  submitted_at    DateTime?       @default(now()) @db.Timestamp(6)
  writing_prompts writing_prompts @relation(fields: [prompt_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users           User            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([prompt_id], map: "idx_writing_submissions_prompt")
  @@index([user_id], map: "idx_writing_submissions_user")
}

enum LessonType {
  grammar
  vocabulary
  practice
}

enum QuestionCategory {
  grammar
  vocabulary
}

enum QuestionType {
  multiple_choice
  fill_blank
  true_false
  matching
}

enum ExamStatus {
  in_progress
  completed
  expired
}

model writing_exercises {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  level_id      String
  exercise_type String    @db.VarChar(50) // 'fill_blank', 'grammar', 'vocabulary'
  sentence      String
  blank_word    String // Doğru cevap
  hint          String?
  options       Json?
  explanation   String?
  difficulty    Int?      @default(1)
  created_at    DateTime? @default(now()) @db.Timestamp(6)

  levels   Level                       @relation(fields: [level_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  attempts writing_exercise_attempts[]

  @@index([level_id], map: "idx_writing_exercises_level")
  @@index([exercise_type], map: "idx_writing_exercises_type")
}

model writing_exercise_attempts {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String
  exercise_id  String    @db.Uuid
  user_answer  String
  is_correct   Boolean
  attempted_at DateTime? @default(now()) @db.Timestamp(6)

  users             User              @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  writing_exercises writing_exercises @relation(fields: [exercise_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, exercise_id])
  @@index([user_id], map: "idx_writing_exercise_attempts_user")
  @@index([exercise_id], map: "idx_writing_exercise_attempts_exercise")
}
